{
  "name": "flowtab",
  "version": "0.1.0",
  "private": true,
  "description": "FlowTab — Restaurant queue & analytics SaaS",
  "scripts": {
    "dev": "echo 'Use docker-compose up for local dev'",
    "build": "tsc -b packages/db packages/config services/queue-service services/analytics-service",
    "lint": "eslint 'services/*/src/**/*.{ts}' 'apps/*/src/**/*.{ts}'",
    "format": "prettier --write '**/*.{ts,json,yaml,yml}'",
    "format:check": "prettier --check '**/*.{ts,json,yaml,yml}'"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
