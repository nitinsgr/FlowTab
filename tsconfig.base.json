{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "paths": {
      "@flowtab/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@flowtab/config": ["../../packages/config/src/index.ts"],
      "@flowtab/db": ["../../packages/db/src/index.ts"]
    }
  }
}
